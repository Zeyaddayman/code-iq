generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Question {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String    @unique
  answers     String[]
  correct     String
  language    Language

  @@map("question")
}

enum Language {
  javascript
  python
  java
  c_plus_plus
}